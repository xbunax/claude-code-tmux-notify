# claude-code-tmux-notify 配置文件
# 路径: ~/.config/claude-code-tmux-notify/config.toml

# 缓冲区行数
buffer_lines = 25

[popup]
width = "25%"
height = "25%"
x = "R"       # R = 右侧
y = "0"       # 0 = 顶部

[hook_server]
enabled = true
host = "127.0.0.1"
port = 19836
ttl = 30.0
require_hook = false   # true = 双确认模式

[triggers.permission]
patterns = ['Do you want to .*\?', 'Would you like to .*\?']
keywords = ["Do you want to", "Would you like to"]

[triggers.plan]
patterns = []
keywords = ["approve this plan", "approve the plan"]

[triggers.completed]
patterns = ['(Brewed|Crunched|Swooped|Drizzled) for\s+']
keywords = []

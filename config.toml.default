# agent-tmux-notify 配置文件
# 路径: ~/.config/agent-tmux-notify/config.toml

# 从 tmux buffer 提取上下文/选项时读取的行数
buffer_lines = 25

[popup]
width = "25%"
height = "25%"
x = "R"       # R = 右侧
y = "0"       # 0 = 顶部

[hook_server]
enabled = true
host = "127.0.0.1"
port = 19836
ttl = 30.0
dump_payloads = false
dump_path = "/tmp/claude-code-hook-payloads.jsonl"

[parse_rules.permission]
patterns = ['Do you want to .*\?', 'Would you like to .*\?']
keywords = ["Do you want to", "Would you like to"]

[parse_rules.plan]
patterns = []
keywords = ["approve this plan", "approve the plan"]
